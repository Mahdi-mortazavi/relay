<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Relay</string>
    <string name="tagline">Share your connection. Instantly.</string>

    <!-- Home -->
    <string name="action_start">Start Sharing</string>
    <string name="action_stop">Stop</string>
    <string name="status_idle">Not sharing</string>
    <string name="status_preparing">Starting…</string>
    <string name="status_waiting">Waiting for your PC…</string>
    <plurals name="status_connected">
        <item quantity="one">%d device connected</item>
        <item quantity="other">%d devices connected</item>
    </plurals>
    <string name="scan_hint">Scan with Relay on your PC</string>
    <string name="or_type_code">or enter this code on your PC</string>
    <string name="traffic_format">↑ %1$s   ↓ %2$s</string>
    <string name="status_reconnecting">Reconnecting…</string>

    <!-- Transport modes -->
    <string name="mode_fast">Fast</string>
    <string name="mode_full">Full</string>
    <string name="mode_fast_desc">Best for browsing and streaming.</string>
    <string name="mode_full_desc">Best for games and video calls.</string>

    <!-- Warnings (non-blocking banners) -->
    <string name="warning_no_vpn_title">No VPN is active</string>
    <string name="warning_no_vpn_body">You\'re sharing your regular connection. Turn on your VPN first if you meant to share it.</string>

    <!-- Advanced -->
    <string name="advanced">Advanced</string>
    <string name="advanced_ip">Hotspot address</string>
    <string name="advanced_port">Preferred port</string>
    <string name="advanced_port_hint">0 = automatic</string>
    <string name="advanced_port_save">Save</string>
    <string name="advanced_theme">Appearance</string>
    <string name="theme_system">System</string>
    <string name="theme_dark">Dark</string>
    <string name="theme_light">Light</string>
    <string name="advanced_logs">Activity log (stays on this device)</string>
    <string name="advanced_logs_clear">Clear</string>
    <string name="advanced_logs_empty">No activity yet</string>

    <!-- Errors (codes: docs/errors.md) -->
    <string name="error_hotspot_off_title">Hotspot is off</string>
    <string name="error_hotspot_off_body">Turn on your phone\'s Wi-Fi hotspot, then try again.</string>
    <string name="error_port_in_use_title">Ports are busy</string>
    <string name="error_port_in_use_body">Another app is using the connection ports Relay needs. Close it, then try again.</string>
    <string name="error_service_failed_title">Something went wrong</string>
    <string name="error_service_failed_body">Sharing stopped unexpectedly. Try starting it again.</string>
    <string name="error_hotspot_lost_title">Hotspot connection lost</string>
    <string name="error_hotspot_lost_body">The hotspot dropped and didn\'t come back. Check it\'s still on, then start sharing again.</string>
    <string name="error_wg_start_title">Couldn\'t start Full Mode</string>
    <string name="error_wg_start_body">The WireGuard tunnel couldn\'t start on this phone. Try Fast Mode, or start sharing again.</string>
    <string name="action_retry">Try Again</string>
    <string name="action_dismiss">Dismiss</string>

    <!-- Battery exemption onboarding (ADR-0003) -->
    <string name="battery_banner_title">Keep sharing alive</string>
    <string name="battery_banner_body">Allow Relay to ignore battery optimization so sharing survives when the screen is off.</string>
    <string name="battery_banner_allow">Allow</string>
    <string name="battery_banner_done">Background sharing is protected</string>

    <!-- Foreground-service notification -->
    <string name="notification_channel">Sharing status</string>
    <string name="notification_starting">Starting…</string>
    <string name="notification_waiting">Sharing is on — waiting for your PC</string>
    <plurals name="notification_connected">
        <item quantity="one">Sharing with %d device</item>
        <item quantity="other">Sharing with %d devices</item>
    </plurals>
    <string name="notification_error">Sharing stopped — open Relay for details</string>
    <string name="notification_reconnecting">Reconnecting…</string>
